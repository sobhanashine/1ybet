# --- Database (Supabase Postgres, pooled connection on port 6543) ---
DATABASE_URL=
# Direct connection to the database (port 5432) used for migrations.
DIRECT_URL=

# --- Auth ---
OTP_CODE=1111
SESSION_SECRET=

# --- Football data (football-data.org free tier) ---
FOOTBALL_DATA_API_KEY=

# --- Cron protection (shared secret sent as x-cron-secret header) ---
CRON_SECRET=

# --- Web Push (VAPID) — generate with: npx web-push generate-vapid-keys ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# --- Email (optional, Resend free tier) ---
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=

# --- Tournament registration-guide video (optional) ---
# Leave unset to serve the file from public/tournament-guide.mp4, or point this
# at a hosted URL (e.g. a CDN). Must start with NEXT_PUBLIC_ to reach the client.
NEXT_PUBLIC_TOURNAMENT_VIDEO_URL=
